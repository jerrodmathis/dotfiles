{
    // THEME
    "workbench.colorTheme": "Catppuccin Mocha",
    "workbench.iconTheme": "catppuccin noctis icons",
    "catppuccin-noctis-icons.hidesExplorerArrows": false,

    // PRETTIER
    "prettier.semi": true,
    "prettier.arrowParens": "always",
    "prettier.bracketSpacing": true,
    "prettier.trailingComma": "all",
    "prettier.tabWidth": 2,
    "prettier.printWidth": 80,
    "prettier.singleQuote": true,
    "prettier.jsxSingleQuote": true,
    "prettier.quoteProps": "as-needed",
    "prettier.bracketSameLine": false,
    "prettier.requireConfig": true,
    "prettier.useEditorConfig": false,

    // EDITOR
    "editor.cursorBlinking": "solid",
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.fontFamily": "Hack Nerd Font",
    "editor.fontLigatures": true,
    "editor.fontSize": 14,
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.guides.bracketPairs": true,
    "editor.minimap.enabled": false,
    "editor.renderWhitespace": "none",
    "editor.tabSize": 2,
    "editor.wordWrapColumn": 80,
    "explorer.sortOrder": "type",
    "workbench.editor.tabActionLocation": "left",

    // VIM
    "vim.enableNeovim": true,
    "vim.neovimPath": "/usr/local/bin/nvim",
    "vim.neovimUseConfigFile": true,
    "vim.neovimConfigPath": "$HOME/.config/nvim",
    "vim.leader": "<space>",
    "vim.hlsearch": false,
    "vim.incsearch": true,
    "vim.ignorecase": true,
    "vim.smartcase": true,
    "vim.smartRelativeLine": true,
    "vim.cursorStylePerMode.insert": "block",
    "vim.cursorStylePerMode.normal": "block",
    "vim.cursorStylePerMode.replace": "block",
    "vim.cursorStylePerMode.visual": "block",
    "vim.cursorStylePerMode.visualblock": "block",
    "vim.cursorStylePerMode.visualline": "block",
    "vim.highlightedyank.enable": true,
    "vim.highlightedyank.color": "rgba(137, 180, 250, 1)",
    "vim.scroll": 20,
    "vim.useSystemClipboard": true,
    "vim.normalModeKeyBindings": [
        {
            "before": ["<leader>", "s", "f"],
            "commands": [
                "workbench.action.quickOpen"
            ]
        },
        {
            "before": ["<leader>", "s", "c"],
            "commands": [
                "workbench.action.showCommands"
            ]
        },
        {
            "before": ["<C-d>"],
            "after": ["<C-d>", "z", "z"],
        },
        {
            "before": ["<C-u>"],
            "after": ["<C-u>", "z", "z"],
        },
        {
            "before": ["<leader>", "w"],
            "commands": [
                "workbench.action.files.save"
            ]
        }
    ],
    "vim.statusBarColorControl": true,
    "vim.statusBarColors.normal": ["#89b4fa", "#181825"],
    "vim.statusBarColors.insert": ["#a6e3a1", "#1e1e2e"],
    "vim.statusBarColors.visual": ["#cba6f7", "#1e1e2e"],
    "vim.statusBarColors.visualline": ["#cba6f7", "#1e1e2e"],
    "vim.statusBarColors.visualblock": ["#cba6f7", "#1e1e2e"],
    "vim.statusBarColors.replace": ["#f38ba8", "#1e1e2e"],
    "vim.statusBarColors.commandlineinprogress": ["#fab387", "#1e1e2e"],
    "extensions.experimental.affinity": {
        "vscode.vim": 1
    },
    "workbench.colorCustomizations": {
        "statusBar.background": "#cba6f7",
        "statusBar.noFolderBackground": "#cba6f7",
        "statusBar.debuggingBackground": "#cba6f7",
        "statusBar.foreground": "#1e1e2e",
        "statusBar.debuggingForeground": "#1e1e2e"
    },
    "vim.handleKeys": {
        "<C-d>": true,
        "<C-s>": false,
        "<C-z>": false
    },

    // GIT
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,

    // OTHER
    "window.commandCenter": true,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.next": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/node_modules": true,
        "**/public": true
    },
    "extensions.ignoreRecommendations": true,
    "explorer.compactFolders": false,
}
